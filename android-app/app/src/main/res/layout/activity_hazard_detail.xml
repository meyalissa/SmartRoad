<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIcon="@drawable/ic_back"
        app:title="@string/hazard_details"
        app:titleTextColor="?attr/colorOnPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/space_md">

            <ImageView
                android:id="@+id/ivHazardPhoto"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/bg_photo_placeholder"
                android:contentDescription="@string/photo"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_gallery" />

            <TextView
                android:id="@+id/tvDetailType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold" />

            <!-- Status timeline: Submitted -> Under Investigation -> Resolved -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartRoad.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_sm"
                        android:text="@string/status_timeline_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/ivStepSubmitted"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_status_resolved" />
                        <TextView
                            android:id="@+id/tvStepSubmitted"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:text="@string/status_submitted"
                            android:textColor="?attr/colorOnSurface" />
                    </LinearLayout>

                    <View
                        android:id="@+id/lineSubmittedToInvestigating"
                        android:layout_width="2dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="9dp"
                        android:background="?attr/colorOnSurfaceVariant" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/ivStepInvestigating"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_circle_outline" />
                        <TextView
                            android:id="@+id/tvStepInvestigating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:text="@string/status_under_investigation"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>

                    <View
                        android:id="@+id/lineInvestigatingToResolved"
                        android:layout_width="2dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="9dp"
                        android:background="?attr/colorOnSurfaceVariant" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:id="@+id/ivStepResolved"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_circle_outline" />
                        <TextView
                            android:id="@+id/tvStepResolved"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/space_sm"
                            android:text="@string/status_resolved"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/rowDescription"
                layout="@layout/item_detail_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md" />

            <include
                android:id="@+id/rowReporter"
                layout="@layout/item_detail_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm" />

            <include
                android:id="@+id/rowLocation"
                layout="@layout/item_detail_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm" />

            <!-- Map preview (lite mode) -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SmartRoad.Card"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/space_sm"
                app:contentPadding="0dp">

                <com.google.android.gms.maps.MapView
                    android:id="@+id/mapDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:liteMode="true"
                    app:mapType="normal" />
            </com.google.android.material.card.MaterialCardView>

            <include
                android:id="@+id/rowDateTime"
                layout="@layout/item_detail_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm" />

            <!-- Maintenance info — hidden entirely when no record exists yet -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardMaintenance"
                style="@style/Widget.SmartRoad.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_sm"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/space_xs"
                        android:text="@string/maintenance_info_title"
                        android:textColor="?attr/colorOnSurface"
                        android:textStyle="bold" />

                    <include
                        android:id="@+id/rowMaintenanceTeam"
                        layout="@layout/item_detail_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm" />

                    <include
                        android:id="@+id/rowRepairDate"
                        layout="@layout/item_detail_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm" />

                    <include
                        android:id="@+id/rowCompletedDate"
                        layout="@layout/item_detail_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm" />

                    <include
                        android:id="@+id/rowMaintenanceNotes"
                        layout="@layout/item_detail_row"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
