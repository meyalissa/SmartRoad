<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================================
         CENTRALIZED COLOR SYSTEM
         Status colors mirror config/BrandColors.java so Java code and
         XML layouts/themes stay in sync from one source of truth.
         ============================================================ -->

    <!-- Primary Brand -->
    <color name="primaryColor">#F5A623</color>          <!-- Golden Orange -->
    <color name="primaryDarkColor">#D98C10</color>      <!-- Dark Gold -->
    <color name="secondaryColor">#F8C547</color>        <!-- Soft Yellow -->
    <color name="accentColor">#FFB300</color>           <!-- Bright Amber -->

    <!-- Background -->
    <color name="backgroundColor">#FFFFFF</color>       <!-- Main yellow background -->
    <color name="surfaceColor">#FFFFFF</color>          <!-- Card background -->

    <!-- Text -->
    <color name="textPrimaryColor">#2E2E2E</color>
    <color name="textSecondaryColor">#6B5A3A</color>

    <color name="errorColor">#C62828</color>

    <!-- On-brand text -->
    <color name="onPrimaryColor">#FFFFFF</color>
    <color name="onSecondaryColor">#FFFFFF</color>

    <!-- Status Badge / marker (New/Investigating/Resolved) -->
    <color name="statusNew">#1E88E5</color>
    <color name="statusResolved">#43A047</color>

    <!-- Launcher -->
    <color name="ic_launcher_background">#F5A623</color>

    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
</resources>
