<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ============================================================
         CENTRALIZED COLOR SYSTEM
         Brand source of truth = config/BrandColors.java
         These XML values mirror BrandColors so layouts/themes
         can reference them. Change branding in ONE place:
         edit BrandColors.java AND these few brand colors below.
         ============================================================ -->

    <!-- Primary Brand -->
    <color name="primaryColor">#F5A623</color>          <!-- Golden Orange -->
    <color name="primaryDarkColor">#D98C10</color>      <!-- Dark Gold -->
    <color name="secondaryColor">#F8C547</color>        <!-- Soft Yellow -->
    <color name="accentColor">#FFB300</color>           <!-- Bright Amber -->

    <!-- Background -->
    <color name="backgroundColor">#FFFFFF</color>       <!-- Main yellow background -->
    <color name="surfaceColor">#FFFFFF</color>          <!-- Card background -->


    <!-- Text -->
    <color name="textPrimaryColor">#2E2E2E</color>
    <color name="textSecondaryColor">#6B5A3A</color>

    <!-- Status / semantic -->
    <color name="successColor">#2E7D32</color>
    <color name="warningColor">#F9A825</color>
    <color name="errorColor">#C62828</color>

    <!-- On-brand text -->
    <color name="onPrimaryColor">#FFFFFF</color>
    <color name="onSecondaryColor">#FFFFFF</color>

    <!-- Hazard marker colors -->
    <color name="mapMarkerPothole">#E53935</color>      <!-- Red -->
    <color name="mapMarkerFlood">#1E88E5</color>        <!-- Blue -->
    <color name="mapMarkerAccident">#FB8C00</color>     <!-- Orange -->
    <color name="mapMarkerTree">#43A047</color>         <!-- Green -->
    <color name="mapMarkerRoadSign">#8E24AA</color>     <!-- Purple -->
    <color name="mapMarkerTrafficLight">#FDD835</color> <!-- Yellow -->

    <!-- Status Badge -->
    <color name="statusNew">#1E88E5</color>
    <color name="statusInvestigation">#F9A825</color>
    <color name="statusResolved">#43A047</color>

    <!-- Launcher -->
    <color name="ic_launcher_background">#F5A623</color>

    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>
</resources>
