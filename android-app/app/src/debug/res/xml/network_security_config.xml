<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Local dev backend only (Laragon PHP server) — cleartext HTTP permitted
         for the Android emulator's host alias and the dev machine's LAN IP.
         Does not affect any other domain; all other traffic still requires HTTPS. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.82.146.84</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
</network-security-config>
